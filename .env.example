# OpenAI-compatible API endpoint. Works with:
#   - OpenAI:     leave OPENAI_BASE_URL blank (or https://api.openai.com/v1)
#   - DeepSeek:   https://api.deepseek.com
#   - Together:   https://api.together.xyz/v1
#   - Groq:       https://api.groq.com/openai/v1
#   - Ollama:     http://localhost:11434/v1
#   - vLLM / any OpenAI-compatible server
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# Model IDs — use whatever your provider exposes.
# RESEARCH runs once per persona (cheap/fast matters).
# SYNTHESIS runs twice per ticker (snapshot + aggregator — quality matters).
OPENAI_MODEL_RESEARCH=gpt-4o-mini
OPENAI_MODEL_SYNTHESIS=gpt-4o

# Web search (optional). When a key is set, the snapshot is grounded in
# live search results (LLM plans queries → provider executes → LLM synthesizes).
# If no key is set, the snapshot falls back to the model's training knowledge.
# Set EITHER one. If both are set, Exa wins by default.
# Pin a specific provider with SEARCH_PROVIDER=exa|tavily.
EXA_API_KEY=        # get one at https://exa.ai
TAVILY_API_KEY=     # get one at https://tavily.com
SEARCH_PROVIDER=    # optional: exa | tavily
