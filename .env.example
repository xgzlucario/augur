# OpenAI-compatible API endpoint. Works with:
#   - OpenAI:     leave OPENAI_BASE_URL blank (or https://api.openai.com/v1)
#   - DeepSeek:   https://api.deepseek.com
#   - Together:   https://api.together.xyz/v1
#   - Groq:       https://api.groq.com/openai/v1
#   - Ollama:     http://localhost:11434/v1
#   - vLLM / any OpenAI-compatible server
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# Model IDs — use whatever your provider exposes.
# RESEARCH runs once per persona (cheap/fast matters).
# SYNTHESIS runs twice per ticker (snapshot + aggregator — quality matters).
OPENAI_MODEL_RESEARCH=gpt-4o-mini
OPENAI_MODEL_SYNTHESIS=gpt-4o

# Web search (optional). If EXA_API_KEY is set, the snapshot is grounded in
# live search results (LLM plans queries → Exa executes → LLM synthesizes).
# If unset, the snapshot falls back to the model's training knowledge.
# Get a key at https://exa.ai
EXA_API_KEY=
