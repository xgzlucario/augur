# OpenAI-compatible API endpoint.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# Model IDs — use whatever your provider exposes.
# RESEARCH runs once per persona (cheap/fast matters).
# SYNTHESIS runs twice per ticker (snapshot + aggregator — quality matters).
OPENAI_MODEL_RESEARCH=gpt-4o-mini
OPENAI_MODEL_SYNTHESIS=gpt-4o

# Web search — REQUIRED. Augur refuses to run without a live search provider:
# the LLM's training data is too stale for investment analysis, and a silent
# fallback to it would produce dangerously out-of-date verdicts.
# Set EITHER key. If both are set, Exa wins by default.
# Pin a specific provider with SEARCH_PROVIDER=exa|tavily.
EXA_API_KEY=        # get one at https://exa.ai
TAVILY_API_KEY=     # get one at https://tavily.com
SEARCH_PROVIDER=    # optional: exa | tavily
